# =============================================================================
# Synaplan Website — Environment Variables
# =============================================================================
# Copy this file:  cp .env.example .env.local  (local dev)
#                  cp .env.example .env         (Docker Compose)
#
# Lines marked [REQUIRED] must be set for the feature to work.
# Lines marked [OPTIONAL] have sensible defaults or enable extra features.
# =============================================================================

# ── PostgreSQL (Docker Compose) ──────────────────────────────────────────────
# Used by the `db` service in docker-compose.yml.
# For local dev without Docker, set DATABASE_URL directly instead.

POSTGRES_USER=synaplan
POSTGRES_PASSWORD=changeme
POSTGRES_DB=synaplan_web

# ── Database [REQUIRED for blog + admin] ─────────────────────────────────────
# Prisma connection string. Adjust host to "db" when running via Docker Compose.

DATABASE_URL=postgresql://synaplan:changeme@localhost:5432/synaplan_web

# ── Admin Authentication [REQUIRED for admin panel] ──────────────────────────
# HMAC signing key for admin session cookies. Min 32 characters.
# Generate one:  openssl rand -hex 32

ADMIN_SESSION_SECRET=

# ── Synaplan API [REQUIRED for AI writing + demo chat] ───────────────────────

SYNAPLAN_API_BASE_URL=https://web.synaplan.com/api/v1
SYNAPLAN_DEMO_BEARER_TOKEN=

# ── Demo Chat Session [REQUIRED for demo chat] ──────────────────────────────
# Signing key for demo chat cookies. Min 16 characters.
# Generate one:  openssl rand -hex 16

DEMO_CHAT_SESSION_SECRET=

# ── GitHub Integration [OPTIONAL] ────────────────────────────────────────────

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Cloudflare Analytics [OPTIONAL] ──────────────────────────────────────────

CLOUDFLARE_ZARAZ_TOKEN=
CLOUDFLARE_ZARAZ_SITE_ID=

# ── Cloudflare Turnstile (CAPTCHA) [OPTIONAL] ────────────────────────────────

NEXT_PUBLIC_CLOUDFLARE_RECAPTCHA_KEY=
CLOUDFLARE_RECAPTCHA_SECRET=

# ── Synaplan Chat Widget [OPTIONAL] ──────────────────────────────────────────
# Embed the Synaplan support chat widget on the marketing site.
# Leave SYNAPLAN_WIDGET_ID empty to disable (open-source default).

SYNAPLAN_WIDGET_ID=
SYNAPLAN_WIDGET_API_URL=https://web.synaplan.com
SYNAPLAN_WIDGET_CONFIG=

# ── Server [OPTIONAL] ───────────────────────────────────────────────────────
# Port for the Next.js server (Docker Compose host mapping).

# PORT=3000
